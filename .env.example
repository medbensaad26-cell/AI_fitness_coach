# Copy to `.env` and fill in real values. Never commit `.env`.
#
# Chat uses Groq via an OpenAI-compatible client (GROQ_API_KEY).
# OPENAI_API_KEY is not used by this project — do not set it unless you change providers.

# --- Secrets (replace placeholders) ---
GROQ_API_KEY=your-groq-api-key-here
SECRET_KEY=change-me-to-a-long-random-string

# --- Database (local Docker Compose defaults) ---
# Compose builds DATABASE_URL for the api service using these values and host `db`.
POSTGRES_USER=fitness
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=fitness_coach

# Used for local (non-Docker) runs against localhost. Inside Compose this is overridden.
# Required — the API will not start without DATABASE_URL and SECRET_KEY.
DATABASE_URL=postgresql+asyncpg://fitness:change-me-db-password@localhost:5432/fitness_coach

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Chat / embeddings (non-secret defaults) ---
GROQ_BASE_URL=https://api.groq.com/openai/v1
CHAT_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
